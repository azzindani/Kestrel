# Kestrel — environment template
# Copy to .env and fill all values before running install.sh / docker-compose up
#
# Exchange API keys — testnet (free, no real money needed for dev):
#   1. Go to https://testnet.bybit.com and create a free account
#   2. Account → API Management → Create New Key
#   3. Select "API Transaction" permissions (read + trade)
#   4. Copy the Key and Secret into API_KEY / API_SECRET below
#   For production: mainnet.bybit.com, TESTNET=false, ENV=prod
#
# Telegram bot (for trade alerts):
#   1. Message @BotFather on Telegram → /newbot → copy the token
#   2. Message @userinfobot to get your chat ID
#
# Docker note: DB_HOST below is for bare-metal. docker-compose.yml overrides
# it to "postgres" (the service name) automatically — leave it as localhost here.

ENV=dev
BOT_ID=dev-BTCUSDT-5m-01

EXCHANGE=bybit
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
TESTNET=true

DB_HOST=localhost
DB_PORT=5432
DB_NAME=kestrel
DB_USER=kestrel
DB_PASSWORD=your_db_password_here

PAIR=BTCUSDT
TIMEFRAME_ENTRY=5m
TIMEFRAME_REGIME=15m

LEVERAGE=20
BUCKET_SIZE_USDT=10.0
MAX_ACTIVE_BUCKETS=1

TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

LOG_LEVEL=DEBUG
