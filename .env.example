# Kestrel — environment template
# Copy to .env and fill all values before running install.sh

ENV=dev
BOT_ID=dev-BTCUSDT-5m-01

EXCHANGE=binance
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
TESTNET=true

DB_HOST=localhost
DB_PORT=5432
DB_NAME=kestrel
DB_USER=kestrel
DB_PASSWORD=your_db_password_here

PAIR=BTCUSDT
TIMEFRAME_ENTRY=5m
TIMEFRAME_REGIME=15m

LEVERAGE=20
BUCKET_SIZE_USDT=10.0
MAX_ACTIVE_BUCKETS=1

TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

LOG_LEVEL=DEBUG
